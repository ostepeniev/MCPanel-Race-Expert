# ── Database ──
DATABASE_URL="postgresql://mcpanel:PASSWORD@localhost:5432/mcpanel?schema=public"

# ── Auth ──
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://mcpanel.yourdomain.com"

# ── KEY CRM ──
KEYCRM_API_KEY="your-api-key-from-settings"
KEYCRM_BASE_URL="https://openapi.keycrm.app/v1"

# ── MonoPay (Monobank Acquiring) ──
MONOPAY_TOKEN="your-merchant-token"
MONOPAY_BASE_URL="https://api.monobank.ua/api/merchant"
MONOPAY_WEBHOOK_SECRET="ecdsa-public-key-for-verification"

# ── 1C Integration ──
ONEC_MODE="disabled"
ONEC_BASE_URL="http://1c-server:8080/myapi"
ONEC_USERNAME="api_user"
ONEC_PASSWORD="api_password"
ONEC_CSV_PATH="/shared/1c-exports"

# ── Logging ──
LOG_LEVEL="info"
LOG_DIR="./logs"

# ── Sync Schedule (cron expressions) ──
SYNC_ENABLED="true"
SYNC_KEYCRM_CRON="0 * * * *"
SYNC_MONOPAY_CRON="30 * * * *"
SYNC_ONEC_CRON="0 2 * * *"
ALERT_CHECK_CRON="*/5 * * * *"
